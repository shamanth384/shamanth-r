rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profile Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == request.auth.uid 
          && data.email is string && data.email.size() < 256
          && (data.displayName == null || (data.displayName is string && data.displayName.size() < 128))
          && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() < 512));
      }

      allow get: if isSignedIn(); // Allow reading profiles for interactions if needed, but let's stick to owner for now or basic info
      allow create, update: if isOwner(userId) && isValidUser(incoming());
    }

    // --- Booking Rules ---
    match /bookings/{bookingId} {
      function isValidBooking(data) {
        return data.userId == request.auth.uid
          && data.topic in ['Project Review', 'Credit Modeling', 'EDA Strategy']
          && data.status in ['pending', 'confirmed', 'cancelled']
          && data.date is string && data.date.size() < 50
          && data.time is string && data.time.size() < 50
          && data.createdAt == request.time;
      }

      function isValidUpdate(data) {
        return data.userId == existing().userId // Immutable field
          && data.topic in ['Project Review', 'Credit Modeling', 'EDA Strategy']
          && data.status in ['pending', 'confirmed', 'cancelled']
          && data.updatedAt == request.time;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(bookingId) && isValidBooking(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidUpdate(incoming())
                       && incoming().diff(existing()).affectedKeys().hasOnly(['topic', 'date', 'time', 'status', 'updatedAt']);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    // --- Credit Record Rules ---
    match /credit_records/{recordId} {
      function isValidCreditRecord(data) {
        return data.userId == request.auth.uid
          && data.age is number && data.age >= 18 && data.age <= 120
          && data.income is number && data.income >= 0
          && data.loanAmount is number && data.loanAmount >= 0
          && data.creditScore is number && data.creditScore >= 300 && data.creditScore <= 850
          && data.status in ['Approved', 'Denied', 'Defaulted']
          && data.createdAt == request.time;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(recordId) && isValidCreditRecord(incoming());
      allow update: if false; // Deny updates for now, or implement strict one
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
